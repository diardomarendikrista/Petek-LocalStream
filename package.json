{
  "name": "petek-localstream",
  "version": "1.0.0",
  "description": "Local LAN video streaming server",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix localstream-be\" \"npm run dev --prefix localstream-fe\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "npm run build --prefix localstream-fe && npm run build --prefix localstream-be && electron-builder"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fs-extra": "^11.3.6",
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.1.1",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.localstream.app",
    "productName": "Petek LocalStream",
    "files": [
      "electron/**/*",
      "localstream-be/dist/**/*",
      "localstream-be/package.json",
      "localstream-fe/dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}